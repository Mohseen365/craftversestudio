generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  DRAFT
  PAYMENT_PENDING
  PAYMENT_VERIFICATION
  CONFIRMED
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  WAITLISTED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                 String   @id @default(cuid())
  name               String
  instagramUsername  String?  @map("instagram_username")
  phone              String
  email              String?
  createdAt          DateTime @default(now()) @map("created_at")

  addresses Address[]
  orders    Order[]

  @@index([phone])
  @@map("users")
}

model Address {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  address String
  city    String
  state   String @default("")
  pincode String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  category       String
  description    String
  price          Int
  productionDays Int      @default(1) @map("production_days")
  active         Boolean  @default(true)
  orderCount     Int      @default(0) @map("order_count")
  createdAt      DateTime @default(now()) @map("created_at")

  images     ProductImage[]
  orderItems OrderItem[]

  @@index([active, category])
  @@map("products")
}

model ProductImage {
  id        String @id @default(cuid())
  productId String @map("product_id")
  imageUrl  String @map("image_url")
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @map("order_number")
  userId          String      @map("user_id")
  status          OrderStatus @default(PAYMENT_PENDING)
  occasionType    String?     @map("occasion_type")
  occasionDate    DateTime?   @map("occasion_date")
  deliveryDate    DateTime    @map("delivery_date")
  quantity        Int         @default(1)
  subtotal        Int
  total           Int
  notes           String?
  giftMessage     String?     @map("gift_message")
  trackingNumber  String?     @map("tracking_number")
  createdAt       DateTime    @default(now()) @map("created_at")

  user                 User                  @relation(fields: [userId], references: [id])
  items                OrderItem[]
  payments             Payment[]
  capacityReservations CapacityReservation[]

  @@index([status])
  @@index([deliveryDate])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  quantity  Int
  price     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @map("order_id")
  amount        Int
  screenshotUrl String?       @map("screenshot_url")
  status        PaymentStatus @default(PENDING)
  verifiedAt    DateTime?     @map("verified_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Capacity {
  id              String   @id @default(cuid())
  date            DateTime @unique @db.Date
  maximumCapacity Int      @map("maximum_capacity")

  reservations CapacityReservation[]

  @@map("capacity")
}

model CapacityReservation {
  id         String @id @default(cuid())
  capacityId String @map("capacity_id")
  orderId    String @map("order_id")
  quantity   Int

  capacity Capacity @relation(fields: [capacityId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId])
  @@map("capacity_reservations")
}
